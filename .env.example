# =============================================================================
# AUTOM8ION CRM - ENVIRONMENT VARIABLES TEMPLATE
# =============================================================================
#
# This file contains all environment variables required for the CRM application.
# Copy this file to .env and fill in the values.
#
# IMPORTANT: Never commit .env files with real credentials to version control.
#
# Variables are organized by:
#   1. Frontend (VITE_*) - Exposed to browser, safe for public keys only
#   2. Supabase Edge Functions - Server-side secrets
#   3. Per-Organization Settings - Configured in app UI, stored in database
#
# =============================================================================


# =============================================================================
# SECTION 1: SUPABASE CONFIGURATION (Required)
# =============================================================================
# Get these from: https://supabase.com/dashboard/project/[project-id]/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here


# =============================================================================
# SECTION 2: GOOGLE SERVICES (Calendar, Drive, YouTube, Gmail, Google Business)
# =============================================================================
# Get these from: https://console.cloud.google.com/apis/credentials
#
# Required APIs to enable:
#   - Google Calendar API
#   - Google Drive API
#   - YouTube Data API v3
#   - My Business Account Management API
#   - My Business Business Information API
#   - Gmail API
#   - Google Chat API
#
# OAuth Consent Screen:
#   - User type: External (or Internal for Google Workspace)
#   - Add scopes for calendar, drive, youtube, gmail
#
# Authorized redirect URIs (add all of these):
#   - https://[supabase-project].supabase.co/functions/v1/google-calendar-oauth
#   - https://[supabase-project].supabase.co/functions/v1/drive-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/gmail-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/social-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/google-chat-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/integrations-oauth-callback

VITE_GOOGLE_CLIENT_ID=your_google_client_id_here.apps.googleusercontent.com


# =============================================================================
# SECTION 3: FACEBOOK / INSTAGRAM / META
# =============================================================================
# Get these from: https://developers.facebook.com/apps
#
# Required products to add:
#   - Facebook Login
#   - Instagram Basic Display
#   - Instagram Graph API
#   - Pages API
#
# OAuth redirect URI:
#   - https://[supabase-project].supabase.co/functions/v1/social-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/integrations-oauth-callback
#
# Required permissions:
#   - pages_show_list
#   - pages_read_engagement
#   - pages_manage_posts
#   - instagram_basic
#   - instagram_content_publish

VITE_FACEBOOK_APP_ID=your_facebook_app_id_here


# =============================================================================
# SECTION 4: LINKEDIN
# =============================================================================
# Get these from: https://www.linkedin.com/developers/apps
#
# Required products:
#   - Sign In with LinkedIn using OpenID Connect
#   - Share on LinkedIn
#   - Marketing Developer Platform (for company pages)
#
# OAuth redirect URI:
#   - https://[supabase-project].supabase.co/functions/v1/social-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/integrations-oauth-callback

VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here


# =============================================================================
# SECTION 5: TIKTOK
# =============================================================================
# Get these from: https://developers.tiktok.com/
#
# Required scopes:
#   - user.info.basic
#   - video.publish
#   - video.upload
#
# OAuth redirect URI:
#   - https://[supabase-project].supabase.co/functions/v1/social-oauth-callback
#   - https://[supabase-project].supabase.co/functions/v1/integrations-oauth-callback

VITE_TIKTOK_CLIENT_KEY=your_tiktok_client_key_here


# =============================================================================
# SECTION 6: QUICKBOOKS ONLINE (QBO)
# =============================================================================
# Get these from: https://developer.intuit.com/app/developer/dashboard
#
# App settings:
#   - Select "Accounting" scope
#   - Environment: Production (after testing in Sandbox)
#
# OAuth redirect URI:
#   - https://[supabase-project].supabase.co/functions/v1/qbo-oauth-callback

VITE_QBO_CLIENT_ID=your_qbo_client_id_here


# =============================================================================
# SECTION 7: SUPABASE EDGE FUNCTION SECRETS
# =============================================================================
# These must be set in Supabase Dashboard:
# Project Settings > Edge Functions > Secrets
#
# IMPORTANT: Do NOT put these in your .env file for security.
# They should ONLY be configured in the Supabase Dashboard.
#
# Copy the template below and configure in Supabase Dashboard:
# -----------------------------------------------------------------------------
#
# # Auto-provided by Supabase (do not set manually):
# SUPABASE_URL=<auto>
# SUPABASE_ANON_KEY=<auto>
# SUPABASE_SERVICE_ROLE_KEY=<auto>
#
# # Google (same client ID as frontend, plus secret)
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
#
# # Facebook / Meta
# FACEBOOK_APP_ID=your_facebook_app_id_here
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here
#
# # LinkedIn
# LINKEDIN_CLIENT_ID=your_linkedin_client_id_here
# LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret_here
#
# # TikTok
# TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
# TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
#
# # QuickBooks Online
# QBO_CLIENT_ID=your_qbo_client_id_here
# QBO_CLIENT_SECRET=your_qbo_client_secret_here
#
# # SendGrid (Email Service)
# # Get from: https://app.sendgrid.com/settings/api_keys
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# SENDGRID_ENCRYPTION_KEY=32_character_hex_string_for_encryption
#
# # AI Providers
# # Anthropic: https://console.anthropic.com/
# # OpenAI: https://platform.openai.com/api-keys
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxx
# OPENAI_API_KEY=sk-xxxxxxxxxxxx
#
# # Phone System Encryption (32 characters)
# # Generate with: openssl rand -hex 16
# PHONE_ENCRYPTION_KEY=your_32_character_encryption_key
#
# # Yelp (Optional - for Yelp reviews)
# # Get from: https://www.yelp.com/developers/v3/manage_app
# YELP_API_KEY=your_yelp_api_key_here
#
# # Application URL (for OAuth callbacks in production)
# APP_URL=https://your-production-domain.com
#
# -----------------------------------------------------------------------------


# =============================================================================
# SECTION 8: PER-ORGANIZATION SETTINGS (Configured in App UI)
# =============================================================================
# These are NOT environment variables. They are configured per-organization
# through the application's Settings pages and stored encrypted in the database.
#
# Twilio (Phone/SMS):
#   - Configure at: Settings > Phone > Connection
#   - Required: Account SID, Auth Token
#   - Get from: https://console.twilio.com/
#
# ElevenLabs (Voice AI):
#   - Configure at: Settings > AI Agents > Voices
#   - Required: API Key
#   - Get from: https://elevenlabs.io/
#
# Custom LLM Providers:
#   - Configure at: Settings > AI Agents > Providers
#   - Supports: OpenAI, Anthropic, Azure OpenAI, custom endpoints
#
# Stripe (Payments):
#   - Configure at: Settings > Payments (if enabled)
#   - Required: Secret Key, Webhook Secret
#   - Get from: https://dashboard.stripe.com/apikeys


# =============================================================================
# SECTION 9: DEVELOPMENT / LOCAL TESTING
# =============================================================================
# For local development, you may also need:
#
# # Supabase CLI local development
# SUPABASE_ACCESS_TOKEN=your_supabase_access_token
#
# # Local function testing
# SUPABASE_FUNCTIONS_URL=http://localhost:54321/functions/v1


# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
#
# Minimum required for basic functionality:
# [ ] VITE_SUPABASE_URL
# [ ] VITE_SUPABASE_ANON_KEY
# [ ] ANTHROPIC_API_KEY (in Supabase secrets)
#
# For Google Calendar integration:
# [ ] VITE_GOOGLE_CLIENT_ID
# [ ] GOOGLE_CLIENT_ID (in Supabase secrets)
# [ ] GOOGLE_CLIENT_SECRET (in Supabase secrets)
#
# For Email functionality:
# [ ] SENDGRID_API_KEY (in Supabase secrets)
# [ ] SENDGRID_ENCRYPTION_KEY (in Supabase secrets)
#
# For Social Media posting:
# [ ] VITE_FACEBOOK_APP_ID
# [ ] FACEBOOK_APP_ID & FACEBOOK_APP_SECRET (in Supabase secrets)
# [ ] VITE_LINKEDIN_CLIENT_ID
# [ ] LINKEDIN_CLIENT_ID & LINKEDIN_CLIENT_SECRET (in Supabase secrets)
#
# For QuickBooks integration:
# [ ] VITE_QBO_CLIENT_ID
# [ ] QBO_CLIENT_ID & QBO_CLIENT_SECRET (in Supabase secrets)
#
# =============================================================================
