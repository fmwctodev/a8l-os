SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
ACCESS_TOKEN=your-user-jwt-bearer-token
MCP_PORT=3100

# Mailgun (platform-level fallback, used by service-role flows like booking,
# anonymous portal auth, report email sender, etc. when no per-org integration
# credentials are stored)
MAILGUN_API_KEY=
MAILGUN_DOMAIN=
MAILGUN_WEBHOOK_SIGNING_KEY=
MAILGUN_REGION=us
