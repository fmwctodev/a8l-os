{
  "name": "20 - System & Utilities",
  "description": "Notifications, user profile/preferences, custom values, Clara assistant (chat, voice, memory), meetings, and Google Calendar sync.",
  "item": [
    {
      "name": "Notifications",
      "item": [
        { "name": "List Notifications", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/notifications?user_id=eq.{{user_id}}&order=created_at.desc&limit=50", "host": ["{{base_rest_url}}"], "path": ["notifications"], "query": [{ "key": "user_id", "value": "eq.{{user_id}}" }, { "key": "order", "value": "created_at.desc" }, { "key": "limit", "value": "50" }] } } },
        { "name": "List Unread Notifications", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Prefer", "value": "count=exact" }], "url": { "raw": "{{base_rest_url}}/notifications?user_id=eq.{{user_id}}&read=eq.false&order=created_at.desc", "host": ["{{base_rest_url}}"], "path": ["notifications"], "query": [{ "key": "user_id", "value": "eq.{{user_id}}" }, { "key": "read", "value": "eq.false" }, { "key": "order", "value": "created_at.desc" }] } } },
        { "name": "Mark Notification as Read", "request": { "method": "PATCH", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"read\": true\n}" }, "url": { "raw": "{{base_rest_url}}/notifications?id=eq.{{notification_id}}", "host": ["{{base_rest_url}}"], "path": ["notifications"], "query": [{ "key": "id", "value": "eq.{{notification_id}}" }] } } },
        { "name": "Mark All Notifications as Read", "request": { "method": "PATCH", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"read\": true\n}" }, "url": { "raw": "{{base_rest_url}}/notifications?user_id=eq.{{user_id}}&read=eq.false", "host": ["{{base_rest_url}}"], "path": ["notifications"], "query": [{ "key": "user_id", "value": "eq.{{user_id}}" }, { "key": "read", "value": "eq.false" }] } } }
