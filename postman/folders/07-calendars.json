{
  "name": "07 - Calendars & Scheduling",
  "description": "Calendars, appointment types, appointments, availability, blocked slots, booking API, and Google Calendar.",
  "item": [
    {
      "name": "Calendars",
      "item": [
        { "name": "List Calendars", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/calendars?select=*,owner:users(id,name,email),department:departments(*)&organization_id=eq.{{org_id}}&order=name.asc", "host": ["{{base_rest_url}}"], "path": ["calendars"], "query": [{ "key": "select", "value": "*,owner:users(id,name,email),department:departments(*)" }, { "key": "organization_id", "value": "eq.{{org_id}}" }, { "key": "order", "value": "name.asc" }] } } },
