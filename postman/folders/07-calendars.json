        { "name": "Update Calendar", "request": { "method": "PATCH", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Calendar Name\"\n}" }, "url": { "raw": "{{base_rest_url}}/calendars?id=eq.{{calendar_id}}", "host": ["{{base_rest_url}}"], "path": ["calendars"], "query": [{ "key": "id", "value": "eq.{{calendar_id}}" }] } } },
        { "name": "Delete Calendar", "request": { "method": "DELETE", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/calendars?id=eq.{{calendar_id}}", "host": ["{{base_rest_url}}"], "path": ["calendars"], "query": [{ "key": "id", "value": "eq.{{calendar_id}}" }] } } }
