{
  "name": "12 - Reputation & Reviews",
  "description": "Reviews, review requests, review providers, reputation reviews, reputation settings, AI analysis, and routing rules.",
  "item": [
    {
      "name": "Reviews",
      "item": [
        { "name": "List Reviews", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/reviews?select=*,contact:contacts(id,first_name,last_name,email,phone),review_request:review_requests(id,public_slug,channel),ai_analysis:review_ai_analysis(*)&organization_id=eq.{{org_id}}&order=received_at.desc&limit=50", "host": ["{{base_rest_url}}"], "path": ["reviews"], "query": [{ "key": "select", "value": "*,contact:contacts(id,first_name,last_name,email,phone),review_request:review_requests(id,public_slug,channel),ai_analysis:review_ai_analysis(*)" }, { "key": "organization_id", "value": "eq.{{org_id}}" }, { "key": "order", "value": "received_at.desc" }, { "key": "limit", "value": "50" }] } } },
        { "name": "Get Review by ID", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/reviews?select=*,contact:contacts(id,first_name,last_name,email,phone),review_request:review_requests(id,public_slug,channel),ai_analysis:review_ai_analysis(*)&id=eq.{{review_id}}", "host": ["{{base_rest_url}}"], "path": ["reviews"], "query": [{ "key": "select", "value": "*,contact:contacts(id,first_name,last_name,email,phone),review_request:review_requests(id,public_slug,channel),ai_analysis:review_ai_analysis(*)" }, { "key": "id", "value": "eq.{{review_id}}" }] } } },
        { "name": "Create Manual Review", "request": { "method": "POST", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"organization_id\": \"{{org_id}}\",\n  \"provider\": \"internal\",\n  \"rating\": 5,\n  \"comment\": \"Great service!\",\n  \"reviewer_name\": \"John Doe\",\n  \"reviewer_email\": \"john@example.com\",\n  \"published\": true,\n  \"received_at\": \"{{$isoTimestamp}}\"\n}" }, "url": { "raw": "{{base_rest_url}}/reviews", "host": ["{{base_rest_url}}"], "path": ["reviews"] } } },
        { "name": "Analyze Review (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"review_id\": \"{{review_id}}\"\n}" }, "url": { "raw": "{{base_edge_url}}/review-ai-analyze", "host": ["{{base_edge_url}}"], "path": ["review-ai-analyze"] } } },
        { "name": "Generate AI Reply (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"review_id\": \"{{review_id}}\",\n  \"tone\": \"professional\"\n}" }, "url": { "raw": "{{base_edge_url}}/review-ai-reply", "host": ["{{base_edge_url}}"], "path": ["review-ai-reply"] } } },
        { "name": "Post Reply to Provider (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"review_id\": \"{{review_id}}\",\n  \"reply_text\": \"Thank you for your feedback!\",\n  \"organization_id\": \"{{org_id}}\",\n  \"provider\": \"google\",\n  \"user_id\": \"{{user_id}}\"\n}" }, "url": { "raw": "{{base_edge_url}}/review-reply-post", "host": ["{{base_edge_url}}"], "path": ["review-reply-post"] } } },
        { "name": "Submit Public Review (Edge Function)", "request": { "method": "POST", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"slug\": \"\",\n  \"rating\": 5,\n  \"comment\": \"Great experience!\",\n  \"reviewer_name\": \"Jane Doe\"\n}" }, "url": { "raw": "{{base_edge_url}}/review-submit", "host": ["{{base_edge_url}}"], "path": ["review-submit"] } } }
      ]
    },
    {
      "name": "Review Requests",
      "item": [
