        { "name": "Create Guardrail", "request": { "method": "POST", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"organization_id\": \"{{org_id}}\",\n  \"name\": \"No competitor mentions\",\n  \"rule_type\": \"content_filter\",\n  \"config\": {\"blocked_terms\": [\"competitor_name\"]},\n  \"enabled\": true,\n  \"priority\": 1\n}" }, "url": { "raw": "{{base_rest_url}}/ai_guardrails", "host": ["{{base_rest_url}}"], "path": ["ai_guardrails"] } } }
