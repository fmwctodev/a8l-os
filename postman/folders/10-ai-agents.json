{
  "name": "10 - AI Agents",
  "description": "AI agent management, knowledge collections, prompt templates, guardrails, AI reports, LLM models, and usage logs.",
  "item": [
    {
      "name": "AI Agents",
      "item": [
        { "name": "List AI Agents", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/ai_agents?organization_id=eq.{{org_id}}&order=name.asc", "host": ["{{base_rest_url}}"], "path": ["ai_agents"], "query": [{ "key": "organization_id", "value": "eq.{{org_id}}" }, { "key": "order", "value": "name.asc" }] } } },
        { "name": "Get AI Agent by ID", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/ai_agents?id=eq.{{agent_id}}", "host": ["{{base_rest_url}}"], "path": ["ai_agents"], "query": [{ "key": "id", "value": "eq.{{agent_id}}" }] } } },
        { "name": "Create AI Agent", "request": { "method": "POST", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"organization_id\": \"{{org_id}}\",\n  \"name\": \"Sales Assistant\",\n  \"description\": \"AI agent for handling sales inquiries\",\n  \"system_prompt\": \"You are a helpful sales assistant.\",\n  \"model_id\": \"\",\n  \"enabled\": true,\n  \"agent_type\": \"conversational\",\n  \"created_by\": \"{{user_id}}\"\n}" }, "url": { "raw": "{{base_rest_url}}/ai_agents", "host": ["{{base_rest_url}}"], "path": ["ai_agents"] } } },
        { "name": "Update AI Agent", "request": { "method": "PATCH", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "Content-Type", "value": "application/json" }, { "key": "Prefer", "value": "return=representation" }], "body": { "mode": "raw", "raw": "{\n  \"name\": \"Updated Agent Name\",\n  \"system_prompt\": \"Updated system prompt.\"\n}" }, "url": { "raw": "{{base_rest_url}}/ai_agents?id=eq.{{agent_id}}", "host": ["{{base_rest_url}}"], "path": ["ai_agents"], "query": [{ "key": "id", "value": "eq.{{agent_id}}" }] } } },
        { "name": "Delete AI Agent", "request": { "method": "DELETE", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/ai_agents?id=eq.{{agent_id}}", "host": ["{{base_rest_url}}"], "path": ["ai_agents"], "query": [{ "key": "id", "value": "eq.{{agent_id}}" }] } } }
      ]
    },
    {
      "name": "AI Agent Executor (Edge Function)",
      "item": [
        { "name": "Execute AI Agent", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"agent_id\": \"{{agent_id}}\",\n  \"contact_id\": \"{{contact_id}}\",\n  \"conversation_id\": \"{{conversation_id}}\",\n  \"message\": \"Help me respond to this customer inquiry\"\n}" }, "url": { "raw": "{{base_edge_url}}/ai-agent-executor", "host": ["{{base_edge_url}}"], "path": ["ai-agent-executor"] } } }
