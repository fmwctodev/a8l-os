{
  "name": "14 - Reporting & Analytics",
  "description": "AI-powered reports, report schedules, dashboard analytics, content AI analytics, and system health checks.",
  "item": [
    {
      "name": "AI Reports",
      "item": [
        { "name": "List AI Reports", "request": { "method": "GET", "header": [{ "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Authorization", "value": "Bearer {{bearer_token}}" }], "url": { "raw": "{{base_rest_url}}/ai_reports?select=*,created_by_user:users!ai_reports_created_by_fkey(id,name,email)&organization_id=eq.{{org_id}}&order=created_at.desc&limit=50", "host": ["{{base_rest_url}}"], "path": ["ai_reports"], "query": [{ "key": "select", "value": "*,created_by_user:users!ai_reports_created_by_fkey(id,name,email)" }, { "key": "organization_id", "value": "eq.{{org_id}}" }, { "key": "order", "value": "created_at.desc" }, { "key": "limit", "value": "50" }] } } },
