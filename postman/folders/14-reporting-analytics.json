        { "name": "Generate AI Report (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"query\": \"Show me a summary of all opportunities closed this month\",\n  \"org_id\": \"{{org_id}}\"\n}" }, "url": { "raw": "{{base_edge_url}}/ai-report-generate", "host": ["{{base_edge_url}}"], "path": ["ai-report-generate"] } } },
        { "name": "Query AI Report (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"report_id\": \"{{report_id}}\",\n  \"question\": \"What is the average deal size?\"\n}" }, "url": { "raw": "{{base_edge_url}}/ai-report-query", "host": ["{{base_edge_url}}"], "path": ["ai-report-query"] } } },
        { "name": "Cleanup AI Reports (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{}" }, "url": { "raw": "{{base_edge_url}}/ai-report-cleanup", "host": ["{{base_edge_url}}"], "path": ["ai-report-cleanup"] } } },
