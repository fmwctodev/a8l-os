              "raw": "{{base_rest_url}}/contacts?select=*,owner:users!contacts_owner_id_fkey(id,name,email),department:departments(*),tags:contact_tags(tag:tags(*))&organization_id=eq.{{org_id}}&status=eq.active&merged_into_contact_id=is.null&order=created_at.desc",
