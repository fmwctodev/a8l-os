                { "key": "select", "value": "*,owner:users!contacts_owner_id_fkey(id,name,email),department:departments(*),tags:contact_tags(tag:tags(*))" },
                { "key": "organization_id", "value": "eq.{{org_id}}" },
                { "key": "status", "value": "eq.active" },
                { "key": "merged_into_contact_id", "value": "is.null" },
                { "key": "order", "value": "created_at.desc" }
              ]
            }
          }
        },
