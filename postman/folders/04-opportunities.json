    },
    {
      "name": "Opportunities",
      "item": [
        {
          "name": "List Opportunities",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Prefer", "value": "count=exact" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/opportunities?select=*,contact:contacts(*,tags:contact_tags(tag:tags(*))),pipeline:pipelines(*),stage:pipeline_stages(*),assigned_user:users!opportunities_assigned_user_id_fkey(*),department:departments(*),lost_reason_ref:lost_reasons(*),custom_field_values:opportunity_custom_field_values(*,custom_field:pipeline_custom_fields(*))&organization_id=eq.{{org_id}}&order=created_at.desc&limit=25&offset=0",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [
                { "key": "select", "value": "*,contact:contacts(*,tags:contact_tags(tag:tags(*))),pipeline:pipelines(*),stage:pipeline_stages(*),assigned_user:users!opportunities_assigned_user_id_fkey(*),department:departments(*),lost_reason_ref:lost_reasons(*),custom_field_values:opportunity_custom_field_values(*,custom_field:pipeline_custom_fields(*))" },
                { "key": "organization_id", "value": "eq.{{org_id}}" },
                { "key": "order", "value": "created_at.desc" },
                { "key": "limit", "value": "25" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Get Opportunity by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/opportunities?select=*,contact:contacts(*,tags:contact_tags(tag:tags(*))),pipeline:pipelines(*),stage:pipeline_stages(*),assigned_user:users!opportunities_assigned_user_id_fkey(*),department:departments(*)&id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [
                { "key": "select", "value": "*,contact:contacts(*,tags:contact_tags(tag:tags(*))),pipeline:pipelines(*),stage:pipeline_stages(*),assigned_user:users!opportunities_assigned_user_id_fkey(*),department:departments(*)" },
                { "key": "id", "value": "eq.{{opportunity_id}}" }
              ]
            }
          }
        },
        {
          "name": "Create Opportunity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_id\": \"{{org_id}}\",\n  \"contact_id\": \"{{contact_id}}\",\n  \"pipeline_id\": \"{{pipeline_id}}\",\n  \"stage_id\": \"{{stage_id}}\",\n  \"assigned_user_id\": \"{{user_id}}\",\n  \"value_amount\": 25000,\n  \"currency\": \"USD\",\n  \"source\": \"inbound\",\n  \"close_date\": \"2026-06-30\",\n  \"created_by\": \"{{user_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/opportunities",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  if (Array.isArray(json) && json.length > 0) {",
                  "    pm.environment.set('opportunity_id', json[0].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Opportunity",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"value_amount\": 30000,\n  \"close_date\": \"2026-07-15\"\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/opportunities?id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [{ "key": "id", "value": "eq.{{opportunity_id}}" }]
            }
          }
        },
        {
          "name": "Move to Stage",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"stage_id\": \"{{stage_id}}\"\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/opportunities?id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [{ "key": "id", "value": "eq.{{opportunity_id}}" }]
            }
          }
        },
        {
          "name": "Close Opportunity (Won)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"won\",\n  \"closed_at\": \"{{$isoTimestamp}}\"\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/opportunities?id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [{ "key": "id", "value": "eq.{{opportunity_id}}" }]
            }
          }
        },
        {
          "name": "Close Opportunity (Lost)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"lost\",\n  \"closed_at\": \"{{$isoTimestamp}}\",\n  \"lost_reason_id\": \"\",\n  \"lost_reason_text\": \"Budget constraints\"\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/opportunities?id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [{ "key": "id", "value": "eq.{{opportunity_id}}" }]
            }
          }
        },
        {
          "name": "Delete Opportunity",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/opportunities?id=eq.{{opportunity_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunities"],
              "query": [{ "key": "id", "value": "eq.{{opportunity_id}}" }]
            }
          }
        },
        {
          "name": "Get Stage History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/opportunity_stage_history?select=*,from_stage:pipeline_stages!opportunity_stage_history_from_stage_id_fkey(id,name),to_stage:pipeline_stages!opportunity_stage_history_to_stage_id_fkey(id,name),changed_by_user:users!opportunity_stage_history_changed_by_user_id_fkey(id,name)&opportunity_id=eq.{{opportunity_id}}&order=changed_at.desc",
              "host": ["{{base_rest_url}}"],
              "path": ["opportunity_stage_history"],
              "query": [
                { "key": "select", "value": "*,from_stage:pipeline_stages!opportunity_stage_history_from_stage_id_fkey(id,name),to_stage:pipeline_stages!opportunity_stage_history_to_stage_id_fkey(id,name),changed_by_user:users!opportunity_stage_history_changed_by_user_id_fkey(id,name)" },
                { "key": "opportunity_id", "value": "eq.{{opportunity_id}}" },
                { "key": "order", "value": "changed_at.desc" }
              ]
            }
          }
        }
      ]
    },
