            },
            "url": {
              "raw": "{{base_rest_url}}/pipeline_stages",
              "host": ["{{base_rest_url}}"],
              "path": ["pipeline_stages"]
            }
          }
        },
        {
          "name": "List Pipeline Stages",
          "request": {
            "method": "GET",
