{
  "name": "04 - Opportunities & Pipelines",
  "description": "Pipeline management, opportunity tracking, stage history, and lost reasons.",
  "item": [
    {
      "name": "Pipelines",
      "item": [
        {
          "name": "List Pipelines",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/pipelines?select=*,department:departments(*),stages:pipeline_stages(*)&organization_id=eq.{{org_id}}&order=sort_order.asc",
              "host": ["{{base_rest_url}}"],
              "path": ["pipelines"],
              "query": [
                { "key": "select", "value": "*,department:departments(*),stages:pipeline_stages(*)" },
                { "key": "organization_id", "value": "eq.{{org_id}}" },
                { "key": "order", "value": "sort_order.asc" }
              ]
            }
          }
        },
        {
          "name": "Get Pipeline by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" }
            ],
            "url": {
              "raw": "{{base_rest_url}}/pipelines?select=*,department:departments(*),stages:pipeline_stages(*),custom_fields:pipeline_custom_fields(*)&id=eq.{{pipeline_id}}",
              "host": ["{{base_rest_url}}"],
              "path": ["pipelines"],
              "query": [
                { "key": "select", "value": "*,department:departments(*),stages:pipeline_stages(*),custom_fields:pipeline_custom_fields(*)" },
                { "key": "id", "value": "eq.{{pipeline_id}}" }
              ]
            }
          }
        },
        {
          "name": "Create Pipeline",
          "request": {
            "method": "POST",
            "header": [
              { "key": "apikey", "value": "{{supabase_anon_key}}" },
              { "key": "Authorization", "value": "Bearer {{bearer_token}}" },
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Prefer", "value": "return=representation" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"organization_id\": \"{{org_id}}\",\n  \"name\": \"Inbound Sales\",\n  \"department_id\": null\n}"
            },
            "url": {
              "raw": "{{base_rest_url}}/pipelines",
              "host": ["{{base_rest_url}}"],
              "path": ["pipelines"]
            }
          }
        },
        {
          "name": "Create Pipeline Stage",
          "request": {
