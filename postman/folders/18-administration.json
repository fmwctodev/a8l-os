        { "name": "Create User (Edge Function)", "request": { "method": "POST", "header": [{ "key": "Authorization", "value": "Bearer {{bearer_token}}" }, { "key": "apikey", "value": "{{supabase_anon_key}}" }, { "key": "Content-Type", "value": "application/json" }], "body": { "mode": "raw", "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"password\": \"SecurePassword123!\",\n  \"name\": \"New User\",\n  \"role_id\": \"\",\n  \"department_id\": \"{{department_id}}\"\n}" }, "url": { "raw": "{{base_edge_url}}/create-user", "host": ["{{base_edge_url}}"], "path": ["create-user"] } } }
